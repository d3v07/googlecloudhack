# ===== GCP / Vertex AI =====
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_APPLICATION_CREDENTIALS=.secrets/your-vertex-sa.json
GOOGLE_CLOUD_STAGING_BUCKET=gs://your-agent-engine-staging-bucket
# Split Agent Engine resources used by production /run.
AGENT_ENGINE_DIAGNOSE_RESOURCE=projects/PROJECT_NUMBER/locations/us-central1/reasoningEngines/DIAGNOSE_ENGINE_ID
AGENT_ENGINE_CANDIDATE_RESOURCE=projects/PROJECT_NUMBER/locations/us-central1/reasoningEngines/CANDIDATE_ENGINE_ID
AGENT_ENGINE_RATIONALE_RESOURCE=projects/PROJECT_NUMBER/locations/us-central1/reasoningEngines/RATIONALE_ENGINE_ID
# Gemini 3 verified on Vertex AI: GEMINI_MODEL=gemini-3-flash-preview with GOOGLE_CLOUD_LOCATION=global.
# Keep the default cheap for local dev/CI; switch both values only for prod/demo runs.
GEMINI_MODEL=gemini-2.5-flash

# ===== MongoDB =====
# Cluster connection string → MCP db tools (find/aggregate/explain/create-index/collection-schema)
MDB_MCP_CONNECTION_STRING=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Atlas Service Account (OAuth client creds) → MCP atlas-* tools (atlas-get-performance-advisor, mongodb-logs)
MDB_MCP_API_CLIENT_ID=
MDB_MCP_API_CLIENT_SECRET=
